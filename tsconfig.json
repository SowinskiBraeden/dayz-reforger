{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "rootDir": "src",
        "outDir": "dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true,
        "allowJs": true,
        "lib": ["es2020"],
        "types": ["node"],
        "moduleResolution": "node",
        "baseUrl": ".",
        "paths": {
            "@util/*": ["src/util/*"],
            "@db/*": ["src/database/*"]
        }
    },
    "include": ["src", "src/types"],
    "exclude": ["node_modules"]
}
