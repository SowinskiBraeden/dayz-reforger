{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "rootDir": "src",
        "outDir": "dist",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true,
        "allowJs": true,
        "baseUrl": "./src",
        "paths": {
            "@util/*": ["util/*"],
            "@db/*": ["database/*"]
        }
    },
    "include": ["src"],
    "exclude": ["node_modules"]
}
